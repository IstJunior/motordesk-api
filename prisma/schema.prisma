// Pay-first signup: holds the encrypted signup token (workshop + admin form
// data, incl. password) while the buyer is at the gateway. Nothing in
// users/workshops is created until the charge confirms; the webhook/poller
// reads this by `reference` to create + activate the workshop.
model PendingSignup {
  id          BigInt    @id @default(autoincrement())
  reference   String    @unique @db.VarChar(120)
  email       String    @db.VarChar(255)
  planCode    String    @map("plan_code") @db.VarChar(64)
  provider    String    @default("epayco") @db.VarChar(32)
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("COP") @db.VarChar(3)
  token       String    @db.Text
  status      String    @default("pending") @db.VarChar(32)
  // MP: preapproval id | epayco: checkout reference — correlates webhook → signup
  providerRef String?   @map("provider_ref") @db.VarChar(255)
  workshopId  BigInt?   @map("workshop_id")
  consumedAt  DateTime? @map("consumed_at") @db.Timestamp(0)
  expiresAt   DateTime  @map("expires_at") @db.Timestamp(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([status])
  @@index([expiresAt])
  @@map("pending_signups")
}

