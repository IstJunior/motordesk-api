  appointmentId  BigInt?   @map("appointment_id")
  channel        String    @db.VarChar(32)
  category       String    @db.VarChar(64)
  type           String    @db.VarChar(128)
  recipient      String?   @db.VarChar(500)
  title          String    @db.VarChar(255)
  body           String
  actionUrl      String?   @map("action_url") @db.VarChar(500)
  status         String    @default("pending") @db.VarChar(32)
  attempts       Int       @default(0)
  nextAttemptAt  DateTime? @map("next_attempt_at") @db.Timestamp(0)
  lastError      String?   @map("last_error")
  metadata       Json?
  sentAt         DateTime? @map("sent_at") @db.Timestamp(0)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop     Workshop?     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt, createdAt])
  @@index([userId, channel, status])
  @@index([workshopId, category])
  @@index([notificationId])
  @@map("notification_deliveries")
}

model ActivityLog {
  id          BigInt    @id @default(autoincrement())
  logName     String?   @map("log_name") @db.VarChar(255)
  description String
  subjectType String?   @map("subject_type") @db.VarChar(255)
  event       String?
  subjectId   BigInt?   @map("subject_id")
  causerType  String?   @map("causer_type") @db.VarChar(255)
  causerId    BigInt?   @map("causer_id")
  properties  Json?
  batchUuid   String?   @map("batch_uuid") @db.VarChar(255)
  createdAt   DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(0)

  @@map("activity_log")
}

model Role {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(255)
  guardName String    @map("guard_name") @db.VarChar(255)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  permissions RoleHasPermission[]
  users       ModelHasRole[]

  @@unique([name, guardName])
  @@map("roles")
}

model Permission {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(255)
  guardName String    @map("guard_name") @db.VarChar(255)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  roles RoleHasPermission[]

  @@unique([name, guardName])
  @@map("permissions")
}

model ModelHasRole {
  roleId    BigInt @map("role_id")
  modelType String @map("model_type") @db.VarChar(255)
  modelId   BigInt @map("model_id")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, modelType, modelId])
  @@map("model_has_roles")
}

model RoleHasPermission {
  permissionId BigInt @map("permission_id")
  roleId       BigInt @map("role_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([permissionId, roleId])
  @@map("role_has_permissions")
}

// ── Checklist System ────────────────────────────────────────────────────────

model ChecklistTemplate {
  id          BigInt   @id @default(autoincrement())
  workshopId  BigInt   @map("workshop_id")
  serviceId   BigInt?  @map("service_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workshop              Workshop                @relation(fields: [workshopId], references: [id])
  service               Service?                @relation(fields: [serviceId], references: [id])
  items                 ChecklistTemplateItem[]
  appointmentChecklists AppointmentChecklist[]

  @@index([workshopId])
  @@index([serviceId])
  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id         BigInt  @id @default(autoincrement())
  templateId BigInt  @map("template_id")
  sortOrder  Int     @default(0) @map("sort_order")
  label      String
  required   Boolean @default(false)

  template         ChecklistTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  appointmentItems AppointmentChecklistItem[]

  @@index([templateId])
  @@map("checklist_template_items")
}

model AppointmentChecklist {
  id            BigInt   @id @default(autoincrement())
  appointmentId BigInt   @unique @map("appointment_id")
  templateId    BigInt?  @map("template_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  appointment Appointment                @relation(fields: [appointmentId], references: [id])
  template    ChecklistTemplate?         @relation(fields: [templateId], references: [id])
  items       AppointmentChecklistItem[]

  @@index([templateId])
  @@map("appointment_checklists")
}

model AppointmentChecklistItem {
  id             BigInt    @id @default(autoincrement())
  checklistId    BigInt    @map("checklist_id")
  templateItemId BigInt?   @map("template_item_id")
  sortOrder      Int       @default(0) @map("sort_order")
  label          String
  completed      Boolean   @default(false)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  completedById  BigInt?   @map("completed_by_id")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  checklist    AppointmentChecklist   @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem? @relation(fields: [templateItemId], references: [id])
  completedBy  User?                  @relation("ChecklistItemCompletedBy", fields: [completedById], references: [id])
  photos       AppointmentPhoto[]

  @@index([checklistId])
  @@index([templateItemId])
  @@index([completedById])
  @@map("appointment_checklist_items")
}

model AppointmentPhoto {
  id              BigInt   @id @default(autoincrement())
  appointmentId   BigInt   @map("appointment_id")
  checklistItemId BigInt?  @map("checklist_item_id")
  uploadedById    BigInt?  @map("uploaded_by_id")
  r2Key           String   @map("r2_key")
  url             String
  caption         String?
  createdAt       DateTime @default(now()) @map("created_at")

  appointment   Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  checklistItem AppointmentChecklistItem? @relation(fields: [checklistItemId], references: [id])
  uploadedBy    User?                     @relation("PhotoUploadedBy", fields: [uploadedById], references: [id])

  @@index([appointmentId])
  @@index([checklistItemId])
  @@map("appointment_photos")
}

// ── Vehicle Catalog ─────────────────────────────────────────────────────────

model VehicleModel {
  id          BigInt   @id @default(autoincrement())
  type        String
  brand       String
  model       String
  yearFrom    Int      @map("year_from")
  yearTo      Int?     @map("year_to")
  engine      String?
  isActive    Boolean  @default(true) @map("is_active")
  createdById BigInt   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy User      @relation("VehicleModelCreator", fields: [createdById], references: [id])
  vehicles  Vehicle[]

  @@index([type])
  @@index([brand])
  @@index([createdById])
  @@map("vehicle_models")
}

// Bandeja / chat de leads y talleres (portado de SmartPOS).
// workshopId null = lead de MotorDesk; con valor = chat de un taller.
model ChatSession {
  id         String    @id @default(uuid()) @db.Uuid
  name       String?   @db.VarChar(120)
  phone      String?   @db.VarChar(40)
  workshopId BigInt?   @map("workshop_id")
  lastAt     DateTime  @default(now()) @map("last_at") @db.Timestamptz(6)
  seenAt     DateTime? @map("seen_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workshop Workshop?     @relation(fields: [workshopId], references: [id])
  messages ChatMessage[]

  @@index([lastAt])
  @@index([workshopId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        BigInt   @id @default(autoincrement())
  sessionId String   @map("session_id") @db.Uuid
  sender    String   @db.VarChar(16) // 'visitante' | 'proveedor'
  text      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, id])
  @@map("chat_messages")
}
