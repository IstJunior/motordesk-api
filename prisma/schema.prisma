generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

enum AiStatus {
  pending
  processing
  done
  failed
}

model User {
  id              BigInt    @id @default(autoincrement())
  authId          String?   @unique @map("auth_id") @db.Uuid
  name            String    @db.VarChar(255)
  email           String    @unique @db.VarChar(255)
  phone           String?   @db.VarChar(32)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(0)
  password        String    @db.VarChar(255)
  rememberToken   String?   @map("remember_token") @db.VarChar(100)
  isSuperAdmin    Boolean   @default(false) @map("is_super_admin")
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(0)

  vehicles                  Vehicle[]
  appointments              Appointment[]              @relation("AppointmentUser")
  workshops                 WorkshopUser[]
  technicianAppointments    Appointment[]              @relation("AppointmentTechnician")
  payments                  Payment[]
  paymentRequests           PaymentRequest[]
  paymentsCreated           Payment[]                  @relation("PaymentCreatedBy")
  technicianSchedules       TechnicianSchedule[]
  manuals                   TechnicalManual[]
  broadcasts                Broadcast[]
  completedChecklistItems   AppointmentChecklistItem[] @relation("ChecklistItemCompletedBy")
  vehicleModels             VehicleModel[]             @relation("VehicleModelCreator")
  uploadedPhotos            AppointmentPhoto[]         @relation("PhotoUploadedBy")
  notifications             Notification[]
  notificationPreferences   NotificationPreference[]
  pushSubscriptions         PushSubscription[]
  notificationDeliveries    NotificationDelivery[]
  inventoryMovementsCreated InventoryMovement[]        @relation("InventoryMovementCreatedBy")
  customerBillingProfile    CustomerBillingProfile?
  sales                     Sale[]                     @relation("SaleCustomer")
  salesCreated              Sale[]                     @relation("SaleCreatedBy")
  electronicInvoices        ElectronicInvoice[]        @relation("ElectronicInvoiceCustomer")

  @@map("users")
}

model Workshop {
  id                 BigInt    @id @default(autoincrement())
  name               String    @db.VarChar(255)
  slug               String    @unique @db.VarChar(255)
  // Código de taller (formato T-0001). Se genera una sola vez al registrarse.
  code               String?   @unique @db.VarChar(16)
  email              String    @unique @db.VarChar(255)
  phone              String?   @db.VarChar(255)
  address            String?   @db.VarChar(255)
  city               String?   @db.VarChar(255)
  country            String    @default("CO") @db.VarChar(2)
  taxId              String?   @map("tax_id") @db.VarChar(255)
  description        String?
  website            String?   @db.VarChar(255)
  vehicleTypes       Json?     @map("vehicle_types")
  workshopType       String    @default("mixed_vehicle") @map("workshop_type") @db.VarChar(64)
  landingConfig      Json?     @map("landing_config")
  // Sistema de módulos por taller (superadmin activa/desactiva). Flags {modulo: bool}.
  enabledModules     Json?     @map("enabled_modules")
  // WhatsApp propio del taller (sesión en el gateway openwa; clientes → bandeja del taller).
  whatsappSession    String?   @map("whatsapp_session") @db.VarChar(64)
  whatsappStatus     String?   @map("whatsapp_status") @db.VarChar(32)
  isActive           Boolean   @default(true) @map("is_active")
  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamp(0)
  subscriptionStatus String    @default("trial") @map("subscription_status") @db.VarChar(255)
  createdAt          DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamp(0)

  users                        WorkshopUser[]
  theme                        WorkshopTheme?
  services                     Service[]
  branches                     WorkshopBranch[]
  appointments                 Appointment[]
  payments                     Payment[]
  schedules                    WorkshopSchedule[]
  technicianSchedules          TechnicianSchedule[]
  aiSummaries                  AiSummary[]
  workshopAiConfigs            WorkshopAiConfig[]
  checklistTemplates           ChecklistTemplate[]
  subscription                 Subscription?
  invoices                     Invoice[]
  paymentTransactions          PaymentTransaction[]
  notifications                Notification[]
  notificationPreferences      NotificationPreference[]
  pushSubscriptions            PushSubscription[]
  notificationDeliveries       NotificationDelivery[]
  inventoryItems               InventoryItem[]
  inventoryMovements           InventoryMovement[]
  paymentGatewayConfigs        WorkshopPaymentGatewayConfig[]
  paymentRequests              PaymentRequest[]
  workshopPaymentWebhookEvents WorkshopPaymentWebhookEvent[]
  fiscalProfile                WorkshopFiscalProfile?
  factusConfig                 WorkshopFactusConfig?
  sales                        Sale[]
  electronicInvoices           ElectronicInvoice[]
  chatSessions                 ChatSession[]

  @@index([isActive])
  @@index([workshopType])
  @@index([slug])
  @@map("workshops")
}

model WorkshopBranch {
  id         BigInt    @id @default(autoincrement())
  workshopId BigInt    @map("workshop_id")
  name       String    @db.VarChar(255)
  address    String?   @db.VarChar(255)
  city       String?   @db.VarChar(255)
  country    String    @default("CO") @db.VarChar(2)
  phone      String?   @db.VarChar(255)
  mapsUrl    String?   @map("maps_url") @db.VarChar(500)
  isPrimary  Boolean   @default(false) @map("is_primary")
  isActive   Boolean   @default(true) @map("is_active")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  workshop     Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([workshopId, isActive, sortOrder])
  @@index([workshopId, isPrimary])
  @@map("workshop_branches")
}

model WorkshopUser {
  id         BigInt    @id @default(autoincrement())
  workshopId BigInt    @map("workshop_id")
  userId     BigInt    @map("user_id")
  role       String    @default("client") @db.VarChar(255)
  isOwner    Boolean   @default(false) @map("is_owner")
  createdAt  DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime? @map("updated_at") @db.Timestamp(0)

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId])
  @@map("workshop_user")
}

model Vehicle {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @map("user_id")
  vehicleModelId BigInt?   @map("vehicle_model_id")
  type           String    @default("car") @db.VarChar(30)
  brand          String    @db.VarChar(255)
  model          String    @db.VarChar(255)
  year           Int
  licensePlate   String?   @map("license_plate") @db.VarChar(255)
  color          String?   @db.VarChar(255)
  vin            String?   @db.VarChar(255)
  kilometers     Int       @default(0)
  engineType     String?   @map("engine_type") @db.VarChar(255)
  transmission   String?   @db.VarChar(255)
  notes          String?
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(0)

  user         User          @relation(fields: [userId], references: [id])
  vehicleModel VehicleModel? @relation(fields: [vehicleModelId], references: [id])
  appointments Appointment[]

  @@index([vehicleModelId])
  @@index([licensePlate])
  @@index([userId])
  @@map("vehicles")
}

model Service {
  id              BigInt    @id @default(autoincrement())
  workshopId      BigInt    @map("workshop_id")
  name            String    @db.VarChar(255)
  description     String?
  durationMinutes Int       @default(60) @map("duration_minutes")
  priceCar        Decimal   @default(0) @map("price_car") @db.Decimal(12, 2)
  priceMotorcycle Decimal   @default(0) @map("price_motorcycle") @db.Decimal(12, 2)
  priceSuv        Decimal   @default(0) @map("price_suv") @db.Decimal(12, 2)
  priceTruck      Decimal   @default(0) @map("price_truck") @db.Decimal(12, 2)
  priceAtv        Decimal?  @map("price_atv") @db.Decimal(10, 2)
  priceVan        Decimal?  @map("price_van") @db.Decimal(10, 2)
  priceElectric   Decimal?  @map("price_electric") @db.Decimal(10, 2)
  priceEscooter   Decimal?  @map("price_escooter") @db.Decimal(10, 2)
  pricePickup     Decimal?  @map("price_pickup") @db.Decimal(10, 2)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamp(0)

  workshop            Workshop             @relation(fields: [workshopId], references: [id])
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  checklistTemplates  ChecklistTemplate[]

  @@index([workshopId])
  @@map("services")
}

model InventoryItem {
  id               BigInt    @id @default(autoincrement())
  workshopId       BigInt    @map("workshop_id")
  sku              String?   @db.VarChar(80)
  name             String    @db.VarChar(255)
  category         String?   @db.VarChar(120)
  itemType         String    @default("consumable") @map("item_type") @db.VarChar(32)
  tracksStock      Boolean   @default(true) @map("tracks_stock")
  unit             String    @default("unidad") @db.VarChar(50)
  costPrice        Decimal   @default(0) @map("cost_price") @db.Decimal(12, 2)
  stockQuantity    Decimal   @default(0) @map("stock_quantity") @db.Decimal(12, 3)
  minStockQuantity Decimal   @default(0) @map("min_stock_quantity") @db.Decimal(12, 3)
  serialNumber     String?   @map("serial_number") @db.VarChar(120)
  storageLocation  String?   @map("storage_location") @db.VarChar(180)
  assetStatus      String?   @map("asset_status") @db.VarChar(32)
  assignedTo       String?   @map("assigned_to") @db.VarChar(180)
  acquiredAt       DateTime? @map("acquired_at") @db.Date
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  workshop  Workshop            @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  movements InventoryMovement[]
  saleItems SaleItem[]

  @@unique([workshopId, sku])
  @@index([workshopId, isActive, name])
  @@index([workshopId, category])
  @@index([workshopId, itemType])
  @@map("inventory_items")
}

model InventoryMovement {
  id          BigInt   @id @default(autoincrement())
  workshopId  BigInt   @map("workshop_id")
  itemId      BigInt   @map("item_id")
  createdById BigInt?  @map("created_by_id")
  type        String   @db.VarChar(32)
  quantity    Decimal  @db.Decimal(12, 3)
  unitCost    Decimal? @map("unit_cost") @db.Decimal(12, 2)
  note        String?
  stockBefore Decimal  @map("stock_before") @db.Decimal(12, 3)
  stockAfter  Decimal  @map("stock_after") @db.Decimal(12, 3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  workshop  Workshop      @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([workshopId, createdAt])
  @@index([itemId, createdAt])
  @@index([createdById])
  @@map("inventory_movements")
}

model Appointment {
  id               BigInt    @id @default(autoincrement())
  workshopId       BigInt    @map("workshop_id")
  userId           BigInt?   @map("user_id")
  vehicleId        BigInt    @map("vehicle_id")
  serviceId        BigInt?   @map("service_id")
  branchId         BigInt?   @map("branch_id")
  technicianId     BigInt?   @map("technician_id")
  scheduledAt      DateTime  @map("scheduled_at") @db.Timestamp(0)
  estimatedEndAt   DateTime? @map("estimated_end_at") @db.Timestamp(0)
  startedAt        DateTime? @map("started_at") @db.Timestamp(0)
  completedAt      DateTime? @map("completed_at") @db.Timestamp(0)
  status           String    @default("pending") @db.VarChar(255)
  customerSymptoms String?   @map("customer_symptoms")
  internalNotes    String?   @map("internal_notes")
  totalAmount      Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  paymentMethod    String?   @map("payment_method") @db.VarChar(255)
  paymentStatus    String    @default("pending") @map("payment_status") @db.VarChar(255)
  aiStatus         AiStatus  @default(pending) @map("ai_status")
  createdAt        DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(0)

  workshop               Workshop               @relation(fields: [workshopId], references: [id])
  user                   User?                  @relation("AppointmentUser", fields: [userId], references: [id])
  vehicle                Vehicle                @relation(fields: [vehicleId], references: [id])
  service                Service?               @relation(fields: [serviceId], references: [id])
  branch                 WorkshopBranch?        @relation(fields: [branchId], references: [id])
  technician             User?                  @relation("AppointmentTechnician", fields: [technicianId], references: [id])
  aiSummary              AiSummary?
  payments               Payment[]
  paymentRequests        PaymentRequest[]
  checklist              AppointmentChecklist?
  appointmentServices    AppointmentService[]
  photos                 AppointmentPhoto[]
  notifications          Notification[]
  notificationDeliveries NotificationDelivery[]
  electronicInvoices     ElectronicInvoice[]

  @@index([scheduledAt])
  @@index([status])
  @@index([technicianId])
  @@index([userId])
  @@index([vehicleId])
  @@index([branchId])
  @@index([workshopId])
  @@map("appointments")
}

model AppointmentService {
  appointmentId BigInt @map("appointment_id")
  serviceId     BigInt @map("service_id")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@id([appointmentId, serviceId])
  @@map("appointment_services")
}

model AiSummary {
  id               BigInt    @id @default(autoincrement())
  appointmentId    BigInt    @unique @map("appointment_id")
  workshopId       BigInt    @map("workshop_id")
  provider         String    @db.VarChar(255)
  model            String    @db.VarChar(255)
  rawSymptoms      String    @map("raw_symptoms")
  customerSummary  String    @map("customer_summary")
  technicianReport String    @map("technician_report")
  diagnoses        Json?
  urgencyLevel     String?   @map("urgency_level") @db.VarChar(255)
  tokensUsed       Int       @default(0) @map("tokens_used")
  costUsd          Decimal   @default(0) @map("cost_usd") @db.Decimal(8, 6)
  createdAt        DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime? @map("updated_at") @db.Timestamp(0)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  workshop    Workshop    @relation(fields: [workshopId], references: [id])

  @@map("ai_summaries")
}

model Payment {
  id                   BigInt    @id @default(autoincrement())
  workshopId           BigInt    @map("workshop_id")
  appointmentId        BigInt    @map("appointment_id")
  userId               BigInt    @map("user_id")
  referenceCode        String    @map("reference_code") @db.VarChar(255)
  method               String    @db.VarChar(255)
  status               String    @db.VarChar(255)
  amount               Decimal   @db.Decimal(12, 2)
  surchargeAmount      Decimal   @default(0) @map("surcharge_amount") @db.Decimal(12, 2)
  totalAmount          Decimal   @map("total_amount") @db.Decimal(12, 2)
  currency             String    @db.VarChar(3)
  gatewayResponse      Json?     @map("gateway_response")
  gatewayTransactionId String?   @map("gateway_transaction_id") @db.VarChar(255)
  provider             String?   @db.VarChar(32)
  paymentRequestId     BigInt?   @map("payment_request_id")
  createdById          BigInt?   @map("created_by_id")
  notes                String?
  paidAt               DateTime? @map("paid_at") @db.Timestamp(0)
  createdAt            DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime? @map("updated_at") @db.Timestamp(0)

  workshop           Workshop            @relation(fields: [workshopId], references: [id])
  appointment        Appointment         @relation(fields: [appointmentId], references: [id], map: "payment_appointment_fk")
  user               User                @relation(fields: [userId], references: [id])
  paymentRequest     PaymentRequest?     @relation(fields: [paymentRequestId], references: [id])
  createdBy          User?               @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  electronicInvoices ElectronicInvoice[]

  @@index([paymentRequestId])
  @@index([createdById])
  @@index([provider, status])
  @@map("payments")
}

model WorkshopPaymentGatewayConfig {
  id                     BigInt    @id @default(autoincrement())
  workshopId             BigInt    @map("workshop_id")
  provider               String    @db.VarChar(32)
  environment            String    @default("sandbox") @db.VarChar(32)
  enabled                Boolean   @default(false)
  displayName            String?   @map("display_name") @db.VarChar(120)
  credentialsEncrypted   String?   @map("credentials_encrypted")
  publicConfig           Json?     @map("public_config")
  webhookSecretEncrypted String?   @map("webhook_secret_encrypted")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt              DateTime? @map("deleted_at") @db.Timestamp(0)

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, provider])
  @@index([workshopId, enabled])
  @@map("workshop_payment_gateway_configs")
}

model PaymentRequest {
  id                    BigInt    @id @default(autoincrement())
  workshopId            BigInt    @map("workshop_id")
  appointmentId         BigInt?   @map("appointment_id")
  userId                BigInt?   @map("user_id")
  paymentId             BigInt?   @map("payment_id")
  provider              String    @db.VarChar(32)
  channel               String    @db.VarChar(32)
  referenceCode         String    @map("reference_code") @db.VarChar(255)
  status                String    @default("draft") @db.VarChar(32)
  amount                Decimal   @db.Decimal(12, 2)
  currency              String    @default("COP") @db.VarChar(3)
  description           String?
  paymentUrl            String?   @map("payment_url")
  qrImageBase64         String?   @map("qr_image_base64")
  providerPaymentId     String?   @map("provider_payment_id") @db.VarChar(255)
  providerTransactionId String?   @map("provider_transaction_id") @db.VarChar(255)
  expiresAt             DateTime? @map("expires_at") @db.Timestamp(0)
  sentAt                DateTime? @map("sent_at") @db.Timestamp(0)
  paidAt                DateTime? @map("paid_at") @db.Timestamp(0)
  metadata              Json?
  providerResponse      Json?     @map("provider_response")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  workshop    Workshop     @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  payments    Payment[]

  @@unique([workshopId, referenceCode])
  @@index([workshopId, status])
  @@index([provider, referenceCode])
  @@index([appointmentId])
  @@index([userId])
  @@map("payment_requests")
}

model WorkshopPaymentWebhookEvent {
  id                    BigInt    @id @default(autoincrement())
  provider              String    @db.VarChar(32)
  eventId               String    @map("event_id") @db.VarChar(255)
  workshopId            BigInt?   @map("workshop_id")
  referenceCode         String?   @map("reference_code") @db.VarChar(255)
  providerTransactionId String?   @map("provider_transaction_id") @db.VarChar(255)
  signatureValid        Boolean   @default(false) @map("signature_valid")
  processedAt           DateTime? @map("processed_at") @db.Timestamp(0)
  rawPayload            Json      @map("raw_payload")
  errorMessage          String?   @map("error_message")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  workshop Workshop? @relation(fields: [workshopId], references: [id])

  @@unique([provider, eventId])
  @@index([provider, referenceCode])
  @@index([workshopId])
  @@map("workshop_payment_webhook_events")
}

model WorkshopTheme {
  id              BigInt    @id @default(autoincrement())
  workshopId      BigInt    @unique @map("workshop_id")
  primaryColor    String    @map("primary_color") @db.VarChar(7)
  secondaryColor  String    @map("secondary_color") @db.VarChar(7)
  accentColor     String    @map("accent_color") @db.VarChar(7)
  backgroundColor String    @map("background_color") @db.VarChar(7)
  surfaceColor    String    @map("surface_color") @db.VarChar(7)
  textColor       String    @map("text_color") @db.VarChar(7)
  textMutedColor  String    @map("text_muted_color") @db.VarChar(7)
  successColor    String    @map("success_color") @db.VarChar(7)
  dangerColor     String    @map("danger_color") @db.VarChar(7)
  logoPath        String?   @map("logo_path") @db.VarChar(255)
  faviconPath     String?   @map("favicon_path") @db.VarChar(255)
  fontHeading     String    @map("font_heading") @db.VarChar(255)
  fontBody        String    @map("font_body") @db.VarChar(255)
  fontMono        String    @map("font_mono") @db.VarChar(255)
  createdAt       DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @map("updated_at") @db.Timestamp(0)

  workshop Workshop @relation(fields: [workshopId], references: [id])

  @@map("workshop_themes")
}

model WorkshopSchedule {
  id         BigInt    @id @default(autoincrement())
  workshopId BigInt    @map("workshop_id")
  dayOfWeek  String    @map("day_of_week") @db.VarChar(255)
  opensAt    DateTime  @default(dbgenerated("'08:00:00'::time without time zone")) @map("opens_at") @db.Time(0)
  closesAt   DateTime  @default(dbgenerated("'18:00:00'::time without time zone")) @map("closes_at") @db.Time(0)
  isClosed   Boolean   @default(false) @map("is_closed")
  createdAt  DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime? @map("updated_at") @db.Timestamp(0)

  workshop Workshop @relation(fields: [workshopId], references: [id])

  @@unique([workshopId, dayOfWeek])
  @@map("workshop_schedules")
}

model TechnicianSchedule {
  id          BigInt    @id @default(autoincrement())
  workshopId  BigInt    @map("workshop_id")
  userId      BigInt    @map("user_id")
  dayOfWeek   String    @map("day_of_week") @db.VarChar(255)
  startsAt    DateTime  @default(dbgenerated("'08:00:00'::time without time zone")) @map("starts_at") @db.Time(0)
  endsAt      DateTime  @default(dbgenerated("'18:00:00'::time without time zone")) @map("ends_at") @db.Time(0)
  isAvailable Boolean   @default(true) @map("is_available")
  createdAt   DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(0)

  workshop Workshop @relation(fields: [workshopId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, dayOfWeek])
  @@index([workshopId])
  @@map("technician_schedules")
}

model TechnicalManual {
  id            BigInt    @id @default(autoincrement())
  title         String    @db.VarChar
  slug          String    @db.VarChar
  brand         String    @db.VarChar
  model         String    @db.VarChar
  year          Int
