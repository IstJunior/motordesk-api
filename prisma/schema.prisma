// ─── Subscriptions (taller → MotorDesk SaaS billing) ───
// 1 tier "MotorDesk Completo" × N intervalos. Providers: mercado_pago (auto-recurrente
// card-on-file con trial) y epayco (link manual por periodo, sin trial). Ver
// src/lib/billing/ para el engine.

model SubscriptionPlan {
  id             BigInt   @id @default(autoincrement())
  code           String   @unique @db.VarChar(64)
  name           String   @db.VarChar(255)
  description    String?
  currency       String   @default("COP") @db.VarChar(3)
  amount         Decimal  @db.Decimal(12, 2)
  intervalMonths Int      @map("interval_months")
  trialDays      Int      @default(0) @map("trial_days")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  subscriptions Subscription[]
  invoices      Invoice[]

  @@index([isActive, sortOrder])
  @@map("subscription_plans")
}

// One subscription per workshop. status: trialing|active|past_due|suspended|canceled
// collectionMode: automatic (MP preapproval) | manual (epayco checkout link per period)
model Subscription {
  id                 BigInt    @id @default(autoincrement())
  workshopId         BigInt    @unique @map("workshop_id")
  planId             BigInt    @map("plan_id")
  provider           String    @db.VarChar(32)
  collectionMode     String    @map("collection_mode") @db.VarChar(16)
  status             String    @default("trialing") @db.VarChar(32)
  trialEndsAt        DateTime? @map("trial_ends_at") @db.Timestamp(0)
  currentPeriodStart DateTime? @map("current_period_start") @db.Timestamp(0)
  currentPeriodEnd   DateTime? @map("current_period_end") @db.Timestamp(0)
  graceEndsAt        DateTime? @map("grace_ends_at") @db.Timestamp(0)
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt         DateTime? @map("canceled_at") @db.Timestamp(0)
  // Mercado Pago card-on-file recurring (preapproval)
  mpPreapprovalId    String?   @map("mp_preapproval_id") @db.VarChar(255)
  mpPayerEmail       String?   @map("mp_payer_email") @db.VarChar(255)
  cardBrand          String?   @map("card_brand") @db.VarChar(32)
  cardLast4          String?   @map("card_last4") @db.VarChar(4)
  lastPaymentAt      DateTime? @map("last_payment_at") @db.Timestamp(0)
  lastFailureAt      DateTime? @map("last_failure_at") @db.Timestamp(0)
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  workshop     Workshop             @relation(fields: [workshopId], references: [id])
  plan         SubscriptionPlan     @relation(fields: [planId], references: [id])
  invoices     Invoice[]
  transactions PaymentTransaction[]

  @@index([status])
  @@index([provider, status])
  @@index([mpPreapprovalId])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// status: open|paid|past_due|void
model Invoice {
  id               BigInt    @id @default(autoincrement())
  subscriptionId   BigInt    @map("subscription_id")
  workshopId       BigInt    @map("workshop_id")
  planId           BigInt    @map("plan_id")
  reference        String    @unique @db.VarChar(120)
  status           String    @default("open") @db.VarChar(32)
  periodStart      DateTime  @map("period_start") @db.Timestamp(0)
  periodEnd        DateTime  @map("period_end") @db.Timestamp(0)
  dueAt            DateTime  @map("due_at") @db.Timestamp(0)
  amount           Decimal   @db.Decimal(12, 2)
  currency         String    @default("COP") @db.VarChar(3)
  hostedPaymentUrl String?   @map("hosted_payment_url") @db.Text
  paidAt           DateTime? @map("paid_at") @db.Timestamp(0)
  attemptCount     Int       @default(0) @map("attempt_count")
  nextRetryAt      DateTime? @map("next_retry_at") @db.Timestamp(0)
  metadata         Json?
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)

  subscription Subscription         @relation(fields: [subscriptionId], references: [id])
  workshop     Workshop             @relation(fields: [workshopId], references: [id])
  plan         SubscriptionPlan     @relation(fields: [planId], references: [id])
  transactions PaymentTransaction[]

  @@index([subscriptionId, status])
  @@index([workshopId, status])
  @@index([status, dueAt])
  @@map("invoices")
}

// status: pending|approved|declined|error
model PaymentTransaction {
  id             BigInt   @id @default(autoincrement())
  invoiceId      BigInt?  @map("invoice_id")
